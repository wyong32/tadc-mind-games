---
import BaseLayout from "../layouts/BaseLayout.astro";
import { relatedGames } from "../data/relatedGames";
import { pageSeo } from "../seo/pages";

const navItems = [
  { label: "Home", href: "/", cue: "Start", detail: "Play online and scan the route hub" },
  { label: "Walkthrough", href: "/walkthrough", cue: "Route", detail: "Run order, replay plan, and safe route logic" },
  { label: "Endings", href: "/endings", cue: "Five", detail: "Known endings and chase order" },
  { label: "Choices", href: "/choices", cue: "Risk", detail: "Trust, doubt, help, follow, delay" },
  { label: "Characters", href: "/characters", cue: "Cast", detail: "Caine, Pomni, and Kinger route signals" },
  { label: "Related Games", href: "/related-games", cue: "More", detail: "Short horror games after TADC Mind Games" },
  { label: "Updates", href: "/updates", cue: "Build", detail: "Version notes and page status" },
];

const mainGameTags = ["Fan Made", "Fangame", "Horror", "Indie", "Multiple Endings", "Ren'Py", "Story Rich", "The Amazing Digital Circus", "Visual Novel"];

const quickStart = [
  { step: "01", title: "Play one blind run", text: "Do not chase everything immediately. Finish one route so the first ending lands properly." },
  { step: "02", title: "Pick a replay mood", text: "Choose trust, doubt, panic, curiosity, or delay before your next run starts." },
  { step: "03", title: "Change the sharpest answer", text: "Return to the choice that felt most uncomfortable and answer with the opposite mood." },
  { step: "04", title: "Track the ending pull", text: "If the scene changes, stay with that mood until the ending path becomes clear." },
];

const endingPreview = [
  { name: "Caine Compliance", route: "Trust Caine", danger: "High", cue: "Obedience, praise, controlled answers" },
  { name: "Caine Defiance", route: "Question Caine", danger: "High", cue: "Suspicion, refusal, direct challenge" },
  { name: "Pomni Panic", route: "Help Pomni", danger: "Medium", cue: "Escape pressure, fear, emotional support" },
  { name: "Kinger Clue", route: "Follow Kinger", danger: "Medium", cue: "Odd hints, slower routes, strange room details" },
  { name: "Mixed Unknown", route: "Blend choices", danger: "Unknown", cue: "Delay, mixed moods, less obvious answers" },
];

const choicePreview = [
  { signal: "Trust", result: "Caine control rises", use: "When you want polished danger" },
  { signal: "Doubt", result: "Defiance pressure rises", use: "When you want sharper reactions" },
  { signal: "Help", result: "Pomni panic shifts", use: "When you want emotional branches" },
  { signal: "Follow", result: "Kinger clues appear", use: "When you want strange detours" },
  { signal: "Delay", result: "Uncertainty builds", use: "When all direct answers feel unsafe" },
];

const featuredRelatedGames = relatedGames.slice(0, 4);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "TADC Mind Games",
      url: "https://tadcmindgames.org",
      description: "Independent TADC Mind Games H5 site for online play, choices, endings, walkthroughs, and updates.",
    },
    {
      "@type": "VideoGame",
      name: "TADC Mind Games",
      url: "https://tadcmindgames.org/",
      image: "https://tadcmindgames.org/images/logo.png",
      genre: ["Horror", "Visual Novel"],
      gamePlatform: ["HTML5", "Windows", "macOS"],
      applicationCategory: "Game",
      author: { "@type": "Organization", name: "PITCHBOX Studios" },
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    },
  ],
};
---

<BaseLayout
  title={pageSeo.home.title}
  description={pageSeo.home.description}
  keywords={pageSeo.home.keywords}
  jsonLd={jsonLd}
  hideHeader
>
  <section class="play-section" id="play" aria-labelledby="home-title">
    <div class="play-fx play-fx-a" aria-hidden="true"></div>
    <div class="play-fx play-fx-b" aria-hidden="true"></div>
    <div class="container play-content">
      <div class="play-title-wrap">
        <p class="play-kicker">Horror Visual Novel · Browser / Windows / macOS</p>
        <h1 id="home-title">TADC Mind Games</h1>
        <p class="play-lead">Step into TADC Mind Games, follow the wrong-looking doors, and use the <a href="/walkthrough">route pages</a> when Caine starts making every answer feel unsafe.</p>
      </div>

      <div class="game-stage" data-game-stage>
        <div class="game-frame">
          <iframe
            title="TADC Mind Games browser game"
            data-src="https://itch.io/embed-upload/17780938?color=0b0710"
            src="about:blank"
            allow="fullscreen; autoplay; gamepad *"
            allowfullscreen
            loading="eager"
          ></iframe>

          <div class="game-mask" data-game-mask>
            <div class="game-mask-bg" aria-hidden="true"></div>
            <div class="game-mask-panel">
              <img src="/images/play-game.webp" alt="TADC Mind Games play preview" width="112" height="112" loading="eager" />
              <button class="game-play-button" type="button" data-play-button aria-label="Play TADC Mind Games">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M9 7.5v9l7-4.5-7-4.5Z" />
                </svg>
                Play Game
              </button>
              <p>Start TADC Mind Games.</p>
            </div>
          </div>
        </div>

        <div class="game-toolbar">
          <div class="game-status" aria-hidden="true"></div>
          <div class="game-actions" aria-label="Game display controls">
            <button type="button" data-fullscreen aria-label="Fullscreen game frame">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 9V4h5v2H6v3H4Zm11-3V4h5v5h-2V6h-3Zm3 9h2v5h-5v-2h3Zm-12 3h3v2H4v-5h2Z" />
              </svg>
            </button>
            <button type="button" data-web-fullscreen aria-label="Toggle web fullscreen mode">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 5h14v14H5V5Zm2 2v10h10V7H7Zm2 2h6v6H9V9Z" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div class="main-game-tags" aria-label="TADC Mind Games tags">
        {mainGameTags.map((tag) => <span>{tag}</span>)}
      </div>
    </div>
  </section>

  <section class="brand-nav-section" aria-labelledby="guide-nav-heading">
    <div class="container brand-nav-content">
      <div class="brand-mark">
        <div class="brand-card">
          <img src="/images/logo.svg" alt="TADC Mind Games logo" width="72" height="72" loading="lazy" />
          <div>
            <p>Game Route Hub</p>
            <h2 id="guide-nav-heading">Routes, endings, and dangerous choices in one haunted little control room.</h2>
          </div>
        </div>
        <p class="brand-proof">Jump from the game into <a href="/endings">endings</a>, <a href="/choices">choices</a>, walkthrough help, and <a href="/updates">version updates</a> without digging through scattered posts.</p>
      </div>

      <nav class="home-nav" aria-label="Homepage navigation">
        {navItems.map((item, index) => (
          <a href={item.href} class:list={[{ "is-primary": index < 2 }]}>
            <span>{item.cue}</span>
            <strong>{item.label}</strong>
            <em>{item.detail}</em>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <section class="quick-start-section" aria-labelledby="quick-start-heading">
    <div class="container quick-start-content">
      <div class="section-heading">
        <p>Quick Start</p>
        <h2 id="quick-start-heading">A compact route plan for your first four runs.</h2>
      </div>
      <div class="quick-start-grid">
        {quickStart.map((item) => (
          <article>
            <span>{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="route-map-section" aria-labelledby="route-map-heading">
    <div class="container route-map-content">
      <div class="section-heading">
        <p>Choice Route Map</p>
        <h2 id="route-map-heading">Every answer pushes the game toward pressure, panic, trust, or collapse.</h2>
      </div>
      <div class="route-board" aria-label="Route map preview">
        <div class="route-node is-start">Enter the Digital Circus</div>
        <div class="route-lines">
          <a href="/choices">Trust Caine</a>
          <a href="/choices">Question Caine</a>
          <a href="/choices">Help Pomni</a>
          <a href="/choices">Follow Kinger</a>
        </div>
        <div class="route-node is-end">Ending Path Unknown</div>
      </div>
    </div>
  </section>

  <section class="ending-preview-section" aria-labelledby="ending-preview-heading">
    <div class="container ending-preview-content">
      <div class="section-heading">
        <p>Ending Tracker</p>
        <h2 id="ending-preview-heading">Five routes, five different kinds of bad idea.</h2>
      </div>
      <div class="ending-preview-table" role="table" aria-label="TADC Mind Games ending tracker preview">
        <div class="ending-preview-row is-head" role="row">
          <span role="columnheader">Ending path</span>
          <span role="columnheader">Route focus</span>
          <span role="columnheader">Danger</span>
          <span role="columnheader">Choice cue</span>
        </div>
        {endingPreview.map((ending) => (
          <a href="/endings" class="ending-preview-row" role="row">
            <span role="cell">{ending.name}</span>
            <span role="cell">{ending.route}</span>
            <span role="cell">{ending.danger}</span>
            <span role="cell">{ending.cue}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cast-section" aria-labelledby="cast-heading">
    <div class="container cast-content">
      <div class="section-heading">
        <p>Current Cast</p>
        <h2 id="cast-heading">Three characters shape most of the danger.</h2>
      </div>
      <div class="cast-grid">
        <article>
          <div class="cast-portrait">
            <img src="/images/characters-01.webp" alt="Caine route preview for TADC Mind Games" width="160" height="160" loading="lazy" />
            <span>Control Route</span>
          </div>
          <div class="cast-copy">
            <h3>Caine</h3>
            <p>The strongest pressure point in the game. Trusting him, praising him, or pushing back can all send the scene toward different <a href="/endings">outcomes</a>.</p>
          </div>
          <div class="cast-links">
            <a href="/characters#character-notes">Character File</a>
            <a href="/choices#caine-pressure-heading">Choice Signals</a>
          </div>
        </article>
        <article>
          <div class="cast-portrait">
            <img src="/images/characters-02.webp" alt="Pomni route atmosphere for TADC Mind Games" width="160" height="160" loading="lazy" />
            <span>Panic Route</span>
          </div>
          <div class="cast-copy">
            <h3>Pomni</h3>
            <p>Pomni choices lean into panic, escape, and emotional pressure. Helping her is not always as simple as choosing the kindest line.</p>
          </div>
          <div class="cast-links">
            <a href="/characters#character-notes">Character File</a>
            <a href="/walkthrough#route-cards-heading">Route Help</a>
          </div>
        </article>
        <article>
          <div class="cast-portrait">
            <img src="/images/characters-03.webp" alt="Kinger clue route background for TADC Mind Games" width="160" height="160" loading="lazy" />
            <span>Clue Route</span>
          </div>
          <div class="cast-copy">
            <h3>Kinger</h3>
            <p>Kinger's path is stranger and slower. Follow odd hints, watch the room, and expect clues that feel more unsettling than obvious.</p>
          </div>
          <div class="cast-links">
            <a href="/characters#character-notes">Character File</a>
            <a href="/endings#ending-tracker-heading">Ending Paths</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="choice-preview-section" aria-labelledby="choice-preview-heading">
    <div class="container choice-preview-content">
      <div class="section-heading">
        <p>Choice Matrix</p>
        <h2 id="choice-preview-heading">Read the mood before you read the line.</h2>
      </div>
      <div class="choice-preview-grid">
        {choicePreview.map((choice) => (
          <a href="/choices">
            <strong>{choice.signal}</strong>
            <span>{choice.result}</span>
            <p>{choice.use}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="related-games-section" id="related-games" aria-labelledby="related-games-heading">
    <div class="container related-games-content">
      <div class="section-heading">
        <p>Related Games</p>
        <h2 id="related-games-heading">More short horror games after TADC Mind Games.</h2>
      </div>
      <div class="related-games-grid">
        {featuredRelatedGames.map((game) => (
          <article>
            <img src={game.imageUrl} alt={game.imageAlt} width="420" height="236" loading="lazy" />
            <div class="related-game-body">
              <div class="related-game-tags">
                {game.tags.map((tag) => <span>{tag}</span>)}
              </div>
              <h3>{game.title}</h3>
              <p>{game.description}</p>
              <a href={`/related-games/${game.addressBar}`}>View Game</a>
            </div>
          </article>
        ))}
      </div>
      <a class="related-games-more" href="/related-games">Open full related games list</a>
    </div>
  </section>

  <section class="faq-section" aria-labelledby="faq-heading">
    <div class="container faq-content">
      <div class="section-heading">
        <p>FAQ</p>
        <h2 id="faq-heading">TADC Mind Games questions players ask first</h2>
      </div>
      <div class="faq-list">
        <details open>
          <summary>Can I play TADC Mind Games online?</summary>
          <p>Yes. Press Play Game at the top of this page to load TADC Mind Games in the browser without leaving the site.</p>
        </details>
        <details>
          <summary>How many endings are in TADC Mind Games?</summary>
          <p>The current build has five ending paths to chase. Start with Caine trust, Caine defiance, Pomni support, Kinger curiosity, then experiment with mixed choices.</p>
        </details>
        <details>
          <summary>Which characters appear in the game?</summary>
          <p>The current visible cast centers on Caine, Pomni, and Kinger. Use the <a href="/characters">TADC Mind Games characters page</a> for route roles, pressure signals, and ending links tied to each character.</p>
        </details>
        <details>
          <summary>Where should I go after my first ending?</summary>
          <p>Open the <a href="/endings">endings hub</a> if you want another outcome, or use the <a href="/choices">choices page</a> if you remember the exact answer that made the route feel dangerous.</p>
        </details>
        <details>
          <summary>Is this an official TADC site?</summary>
          <p>No. This is an independent H5 game site for players. TADC Mind Games is a fan-made horror visual novel inspired by The Amazing Digital Circus.</p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const stage = document.querySelector("[data-game-stage]");
  const iframe = stage?.querySelector("iframe");
  const playButton = stage?.querySelector("[data-play-button]");
  const mask = stage?.querySelector("[data-game-mask]");
  const statusText = stage?.querySelector("[data-game-status]");
  const fullscreenButton = stage?.querySelector("[data-fullscreen]");
  const webFullscreenButton = stage?.querySelector("[data-web-fullscreen]");
  let loaded = false;

  // 点击后只设置一次 iframe src，后续全屏切换不会重建游戏。
  const loadGame = () => {
    if (!iframe || loaded) return;
    iframe.setAttribute("src", iframe.getAttribute("data-src") || "about:blank");
    loaded = true;
    stage?.classList.add("is-playing");
    mask?.setAttribute("aria-hidden", "true");
    if (statusText) statusText.textContent = "";
  };

  playButton?.addEventListener("click", loadGame);

  fullscreenButton?.addEventListener("click", async () => {
    loadGame();
    const frame = stage?.querySelector(".game-frame");
    if (frame && "requestFullscreen" in frame) await frame.requestFullscreen();
  });

  webFullscreenButton?.addEventListener("click", () => {
    loadGame();
    stage?.classList.toggle("is-web-fullscreen");
    document.body.classList.toggle("is-game-expanded", stage?.classList.contains("is-web-fullscreen"));
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && stage?.classList.contains("is-web-fullscreen")) {
      stage.classList.remove("is-web-fullscreen");
      document.body.classList.remove("is-game-expanded");
    }
  });
</script>

<style>
  :global(body.is-game-expanded) {
    overflow: hidden;
  }

  .play-section {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: 100svh;
    padding-block: clamp(18px, 3vw, 34px) clamp(28px, 4vw, 48px);
    background:
      linear-gradient(180deg, rgba(5, 3, 8, 0.38), rgba(5, 3, 8, 0.78)),
      url("/images/bg-01.webp") center / cover no-repeat;
  }

  .play-section::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background:
      radial-gradient(ellipse at 50% -10%, rgba(246, 184, 62, 0.32), transparent 34rem),
      linear-gradient(90deg, rgba(84, 216, 238, 0.18), transparent 25%, transparent 72%, rgba(214, 77, 100, 0.22)),
      repeating-linear-gradient(90deg, rgba(248, 240, 231, 0.05) 0 1px, transparent 1px 96px);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .play-section::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    content: "";
    background:
      linear-gradient(115deg, transparent 0 18%, rgba(246, 184, 62, 0.12) 19%, transparent 29%),
      linear-gradient(250deg, transparent 0 55%, rgba(84, 216, 238, 0.1) 56%, transparent 68%);
    filter: blur(0.3px);
    opacity: 0.9;
    pointer-events: none;
  }

  .play-fx {
    position: absolute;
    inset: auto;
    z-index: -1;
    width: 36vw;
    height: 36vw;
    border-radius: 999px;
    filter: blur(70px);
    opacity: 0.42;
    pointer-events: none;
  }

  .play-fx-a {
    top: 5%;
    left: -9%;
    background: var(--cyan);
  }

  .play-fx-b {
    right: -10%;
    bottom: 0;
    background: var(--rose);
  }

  .play-content {
    display: grid;
    gap: clamp(14px, 2.2vw, 24px);
  }

  .play-title-wrap {
    display: grid;
    justify-items: center;
    gap: 8px;
    max-width: 920px;
    margin-inline: auto;
    text-align: center;
  }

  .play-kicker {
    color: var(--gold);
    font-size: clamp(11px, 1.4vw, 13px);
    font-weight: 900;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-shadow: 0 0 18px rgba(246, 184, 62, 0.45);
  }

  .play-title-wrap h1 {
    font-size: clamp(38px, 5vw, 70px);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    text-shadow:
      0 4px 0 rgba(122, 36, 56, 0.9),
      0 0 22px rgba(246, 184, 62, 0.34),
      0 0 52px rgba(214, 77, 100, 0.42);
  }

  .play-lead {
    max-width: 680px;
    color: rgba(248, 240, 231, 0.82);
    font-size: clamp(15px, 1.5vw, 18px);
    line-height: 1.55;
  }

  .main-game-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: -2px;
  }

  .main-game-tags span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 34px;
    padding: 0 14px;
    border: 1px solid rgba(248, 240, 231, 0.14);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgba(248, 240, 231, 0.08), rgba(248, 240, 231, 0.03)),
      rgba(8, 5, 10, 0.62);
    color: rgba(248, 240, 231, 0.82);
    font-size: 13px;
    font-weight: 900;
    box-shadow: inset 0 0 18px rgba(246, 184, 62, 0.04);
  }

  .main-game-tags span::before {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--gold);
    box-shadow: 0 0 12px rgba(246, 184, 62, 0.78);
    content: "";
  }

  .game-stage {
    position: relative;
    width: min(100%, clamp(700px, 58vw, 980px));
    margin-inline: auto;
    padding: clamp(10px, 1.5vw, 18px);
    border: 1px solid rgba(248, 240, 231, 0.16);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
      rgba(8, 4, 11, 0.64);
    box-shadow:
      0 28px 90px rgba(0, 0, 0, 0.68),
      0 0 0 1px rgba(84, 216, 238, 0.13),
      0 0 60px rgba(214, 77, 100, 0.28);
    backdrop-filter: blur(18px);
  }

  .game-stage::before {
    position: absolute;
    inset: -1px;
    z-index: -1;
    border-radius: 24px;
    content: "";
    background: linear-gradient(120deg, rgba(84, 216, 238, 0.7), transparent 24%, rgba(246, 184, 62, 0.5) 52%, transparent 70%, rgba(214, 77, 100, 0.76));
    opacity: 0.5;
  }

  .game-frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid rgba(248, 240, 231, 0.72);
    border-radius: 18px 18px 4px 4px;
    background: #030205;
  }

  .game-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    background: #030205;
  }

  .game-mask {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 20px;
    background: rgba(2, 1, 3, 0.46);
    transition: opacity 0.38s var(--ease), visibility 0.38s var(--ease);
  }

  .game-mask-bg {
    position: absolute;
    inset: -22px;
    background:
      linear-gradient(rgba(5, 2, 7, 0.82), rgba(5, 2, 7, 0.82)),
      url("/images/play-game.webp") center / cover no-repeat;
    filter: blur(18px) saturate(1.16);
    transform: scale(1.08);
  }

  .game-mask-panel {
    position: relative;
    z-index: 1;
    display: grid;
    justify-items: center;
    gap: 18px;
    width: min(100%, 330px);
    padding: 30px 24px;
    border: 1px solid rgba(246, 184, 62, 0.24);
    border-radius: 28px;
    background: rgba(10, 5, 12, 0.46);
    box-shadow: inset 0 0 70px rgba(84, 216, 238, 0.1), 0 0 50px rgba(214, 77, 100, 0.28);
    backdrop-filter: blur(16px);
  }

  .game-mask-panel img {
    width: 96px;
    height: 96px;
    border: 2px solid rgba(248, 240, 231, 0.56);
    border-radius: 22px;
    box-shadow: 0 0 28px rgba(84, 216, 238, 0.24), 0 0 42px rgba(214, 77, 100, 0.34);
    object-fit: cover;
  }

  .game-play-button {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 54px;
    padding: 0 28px;
    border: 1px solid rgba(248, 240, 231, 0.64);
    border-radius: 999px;
    background: linear-gradient(135deg, #ffe28a, #ff7a77 48%, #d64d64);
    color: #22090f;
    cursor: pointer;
    font: 900 16px / 1 var(--font-body);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    box-shadow: 0 12px 36px rgba(214, 77, 100, 0.46), 0 0 22px rgba(246, 184, 62, 0.32);
